{
  "name": "html-presentation",
  "version": "1.0.0",
  "description": "Personal portfolio and presentation page",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "lint:html": "htmlhint index.html",
    "lint:css": "stylelint \"src/css/**/*.css\"",
    "lint": "npm run lint:html && npm run lint:css",
    "format": "prettier --write \"**/*.{html,css,js,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "htmlhint": "^1.1.4",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^36.0.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "**/*.{html,css,js,md}": "prettier --write",
    "src/css/**/*.css": "stylelint",
    "index.html": "htmlhint"
  }
}
